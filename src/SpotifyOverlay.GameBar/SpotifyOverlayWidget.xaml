<Page
    x:Class="SpotifyOverlay.GameBar.SpotifyOverlayWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SpotifyOverlay.GameBar"
    xmlns:models="using:SpotifyOverlay.GameBar.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#1DB954"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#121212"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtextBrush" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#282828"/>
        
        <FontFamily x:Key="SymbolFont">Segoe MDL2 Assets</FontFamily>

        <DataTemplate x:Key="TrackItemTemplate" x:DataType="models:TrackUIModel">
            <Grid Padding="0,8" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Source="{x:Bind ImageSource, Mode=OneWay}" Width="48" Height="48" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Artist, Mode=OneWay}" Foreground="{StaticResource SubtextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="4" VerticalAlignment="Center" Padding="4,2" Margin="8,0,0,0">
                    <TextBlock Text="{x:Bind ItemTypeBadge, Mode=OneWay}" Foreground="{StaticResource SubtextBrush}" FontSize="10" FontWeight="Bold"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlaylistItemTemplate" x:DataType="models:PlaylistUIModel">
            <Grid Padding="0,8" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="{x:Bind ImageSource, Mode=OneWay}" Width="48" Height="48" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}" Foreground="{StaticResource SubtextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="LyricLineTemplate" x:DataType="models:LyricLineUIModel">
            <TextBlock Text="{x:Bind Text, Mode=OneWay}" 
                       FontSize="16" 
                       FontWeight="{x:Bind FontWeight, Mode=OneWay}" 
                       Foreground="{x:Bind Foreground, Mode=OneWay}" 
                       TextWrapping="Wrap" 
                       Margin="0,6"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" DoubleTapped="Grid_DoubleTapped">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <NavigationView x:Name="NavView" PaneDisplayMode="Top" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" Background="Transparent" SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Player" Tag="Player" />
                <NavigationViewItem Content="Search" Tag="Search" />
                <NavigationViewItem Content="Playlists" Tag="Playlists" />
                <NavigationViewItem Content="Queue" Tag="Queue" />
                <NavigationViewItem Content="Lyrics" Tag="Lyrics" />
                <NavigationViewItem Content="Settings" Tag="Settings" />
            </NavigationView.MenuItems>
        </NavigationView>

        <Button x:Name="ModeToggleButton" Content="&#xE740;" FontFamily="{StaticResource SymbolFont}" Click="ModeToggleButton_Click" Background="Transparent" Foreground="{StaticResource TextBrush}" BorderThickness="0" Margin="4,4,4,4" HorizontalAlignment="Right" VerticalAlignment="Top" Canvas.ZIndex="100"/>

        <Grid Grid.Row="1" x:Name="ContentGrid" Padding="8,0">
            <!-- Global UI States -->
            <ProgressRing x:Name="LoadingSpinner" IsActive="False" Width="40" Height="40" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10"/>
            <TextBlock x:Name="EmptyStateText" Text="No results found." Visibility="Collapsed" Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10"/>
            <Border x:Name="ErrorStatePanel" Visibility="Collapsed" Background="#44FF0000" CornerRadius="4" Padding="12" VerticalAlignment="Top" Margin="8" Canvas.ZIndex="10">
                <TextBlock x:Name="ErrorStateText" Foreground="{StaticResource TextBrush}" FontWeight="Bold" TextWrapping="Wrap"/>
            </Border>

            <!-- Player Layout -->
            <Grid x:Name="PlayerPanel" Visibility="Visible" Padding="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border x:Name="PlayerAlbumArtBorder" Grid.Row="0" Width="140" Height="140" CornerRadius="8" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock Text="&#xE8D6;" FontFamily="{StaticResource SymbolFont}" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource SubtextBrush}"/>
                        <Image x:Name="PlayerAlbumArt" Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock x:Name="TrackTitleText" Text="Track Title" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxLines="2"/>
                    <TextBlock x:Name="ArtistNameText" Text="Artist Name" FontSize="12" Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" TextAlignment="Center" TextWrapping="Wrap" MaxLines="1"/>
                </StackPanel>
                <Grid Grid.Row="2" Margin="0,0,0,10" MaxWidth="300" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressCurrentText" Text="0:00" Foreground="{StaticResource SubtextBrush}" FontSize="10" VerticalAlignment="Center"/>
                    <ProgressBar x:Name="ProgressBar" Grid.Column="1" Value="0" Maximum="100" Margin="8,0" Foreground="{StaticResource AccentBrush}" Background="{StaticResource PanelBrush}" Height="3"/>
                    <TextBlock x:Name="ProgressDurationText" Grid.Column="2" Text="0:00" Foreground="{StaticResource SubtextBrush}" FontSize="10" VerticalAlignment="Center"/>
                </Grid>
                <Grid x:Name="VolumeControlGrid" Grid.Row="3" Margin="0,0,0,10" MaxWidth="300" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE994;" FontFamily="{StaticResource SymbolFont}" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0" Maximum="1" StepFrequency="0.01" ValueChanged="VolumeSlider_ValueChanged"/>
                </Grid>
                <StackPanel x:Name="PlaybackControlsPanel" Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                    <Button x:Name="PrevButton" Click="PrevButton_Click" Background="Transparent" Foreground="{StaticResource TextBrush}" Content="&#xE892;" FontFamily="{StaticResource SymbolFont}" FontSize="20" BorderThickness="0" VerticalAlignment="Center"/>
                    <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click" Background="{StaticResource TextBrush}" Foreground="Black" Content="&#xE768;" FontFamily="{StaticResource SymbolFont}" FontSize="16" BorderThickness="0" CornerRadius="20" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button x:Name="NextButton" Click="NextButton_Click" Background="Transparent" Foreground="{StaticResource TextBrush}" Content="&#xE893;" FontFamily="{StaticResource SymbolFont}" FontSize="20" BorderThickness="0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Search Layout -->
            <Grid x:Name="SearchPanel" Visibility="Collapsed" Padding="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="SearchBox" PlaceholderText="Search for songs or artists..." Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Height="40" Margin="12,0,12,12" TextChanged="SearchBox_TextChanged"/>
                <ListView x:Name="SearchResultsList" Grid.Row="1" ItemTemplate="{StaticResource TrackItemTemplate}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="TrackItem_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Playlists Layout -->
            <Grid x:Name="PlaylistsPanel" Visibility="Collapsed" Padding="0,12,0,0">
                <ListView x:Name="PlaylistsList" ItemTemplate="{StaticResource PlaylistItemTemplate}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="PlaylistItem_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Playlist Detail Layout -->
            <Grid x:Name="PlaylistDetailPanel" Visibility="Collapsed" Padding="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button x:Name="PlaylistDetailBackButton" Content="&#xE72B;" FontFamily="{StaticResource SymbolFont}" Background="Transparent" Foreground="{StaticResource TextBrush}" BorderThickness="0" Margin="0,0,0,8" Click="PlaylistDetailBackButton_Click"/>
                
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="PlaylistDetailCover" Width="64" Height="64" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="PlaylistDetailName" Text="Playlist Name" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="PlaylistDetailCount" Text="0 tracks" Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <ListView x:Name="PlaylistTracksList" Grid.Row="2" ItemTemplate="{StaticResource TrackItemTemplate}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="PlaylistTrackItem_ItemClick" ContainerContentChanging="PlaylistTracksList_ContainerContentChanging">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Artist Detail Layout -->
            <Grid x:Name="ArtistDetailPanel" Visibility="Collapsed" Padding="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button x:Name="ArtistDetailBackButton" Content="&#xE72B;" FontFamily="{StaticResource SymbolFont}" Background="Transparent" Foreground="{StaticResource TextBrush}" BorderThickness="0" Margin="0,0,0,8" Click="ArtistDetailBackButton_Click"/>
                
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="ArtistDetailImage" Width="64" Height="64" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="ArtistDetailName" Text="Artist Name" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ArtistDetailFollowers" Text="0 Followers" Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock x:Name="ArtistDetailGenres" Text="Genres" Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ArtistDetailPopularity" Text="Popularity: 0/100" Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <Button x:Name="ArtistDetailPlayButton" Grid.Row="2" Background="{StaticResource AccentBrush}" Foreground="Black" BorderThickness="0" CornerRadius="4" Margin="0,0,0,12" Click="ArtistDetailPlayButton_Click" HorizontalAlignment="Left" Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE768;" FontFamily="{StaticResource SymbolFont}" VerticalAlignment="Center" />
                        <TextBlock Text="Play Artist" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <ListView x:Name="ArtistTracksList" Grid.Row="3" ItemTemplate="{StaticResource TrackItemTemplate}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="ArtistTrackItem_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Queue Layout -->
            <Grid x:Name="QueuePanel" Visibility="Collapsed" Padding="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Queue is read-only (Spotify API limitation: no arbitrary queue jumping)." Foreground="{StaticResource SubtextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12" FontStyle="Italic"/>
                <ListView x:Name="QueueList" Grid.Row="1" ItemTemplate="{StaticResource TrackItemTemplate}" SelectionMode="None" IsItemClickEnabled="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Lyrics Layout -->
            <Grid x:Name="LyricsPanel" Visibility="Collapsed" Padding="0,12,0,0">
                <TextBlock x:Name="LyricsUnavailableText" Text="Lyrics unavailable for this track." Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                <ListView x:Name="LyricsList" ItemTemplate="{StaticResource LyricLineTemplate}" SelectionMode="None" IsItemClickEnabled="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Settings Layout -->
            <Grid x:Name="SettingsPanel" Visibility="Collapsed" Padding="12">
                <StackPanel Spacing="12">
                    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    
                    <ComboBox x:Name="ThemeComboBox" Header="Theme" Width="200" SelectionChanged="ThemeComboBox_SelectionChanged" Foreground="{StaticResource TextBrush}">
                        <x:String>SpotifyOverlay Default</x:String>
                        <x:String>Spotify Dark</x:String>
                        <x:String>Xbox Dark</x:String>
                        <x:String>Fluent Light</x:String>
                        <x:String>AMOLED</x:String>
                    </ComboBox>

                    <ToggleSwitch x:Name="NotifyTrackToggle" Header="Track Change Notifications" Toggled="SettingToggle_Toggled" Foreground="{StaticResource TextBrush}"/>
                    <ToggleSwitch x:Name="NotifyQueueToggle" Header="Queue Notifications" Toggled="SettingToggle_Toggled" Foreground="{StaticResource TextBrush}"/>
                    <ToggleSwitch x:Name="NotifyDeviceToggle" Header="Device Notifications" Toggled="SettingToggle_Toggled" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Page>
