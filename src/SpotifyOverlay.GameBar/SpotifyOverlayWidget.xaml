<Page
    x:Class="SpotifyOverlay.GameBar.SpotifyOverlayWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SpotifyOverlay.GameBar"
    xmlns:models="using:SpotifyOverlay.GameBar.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="SpotifyGreen" Color="#1DB954"/>
        <SolidColorBrush x:Key="SpotifyDark" Color="#121212"/>
        <SolidColorBrush x:Key="SpotifyGray" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="SpotifyLightGray" Color="#282828"/>
        <FontFamily x:Key="SymbolFont">Segoe MDL2 Assets</FontFamily>

        <DataTemplate x:Key="TrackItemTemplate" x:DataType="models:TrackUIModel">
            <Grid Padding="0,8" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="{x:Bind ImageSource, Mode=OneWay}" Width="48" Height="48" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Artist, Mode=OneWay}" Foreground="{StaticResource SpotifyGray}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlaylistItemTemplate" x:DataType="models:PlaylistUIModel">
            <Grid Padding="0,8" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="{x:Bind ImageSource, Mode=OneWay}" Width="48" Height="48" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}" Foreground="{StaticResource SpotifyGray}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{StaticResource SpotifyDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <NavigationView x:Name="NavView" PaneDisplayMode="Top" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" Background="#000000" SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Player" Tag="Player" />
                <NavigationViewItem Content="Search" Tag="Search" />
                <NavigationViewItem Content="Playlists" Tag="Playlists" />
                <NavigationViewItem Content="Queue" Tag="Queue" />
            </NavigationView.MenuItems>
        </NavigationView>

        <Grid Grid.Row="1" x:Name="ContentGrid" Padding="8,0">
            <!-- Global UI States -->
            <ProgressRing x:Name="LoadingSpinner" IsActive="False" Width="40" Height="40" Foreground="{StaticResource SpotifyGreen}" HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10"/>
            <TextBlock x:Name="EmptyStateText" Text="No results found." Visibility="Collapsed" Foreground="{StaticResource SpotifyGray}" HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10"/>
            <Border x:Name="ErrorStatePanel" Visibility="Collapsed" Background="#44FF0000" CornerRadius="4" Padding="12" VerticalAlignment="Top" Margin="8" Canvas.ZIndex="10">
                <TextBlock x:Name="ErrorStateText" Foreground="White" FontWeight="Bold" TextWrapping="Wrap"/>
            </Border>

            <!-- Player Layout -->
            <Grid x:Name="PlayerPanel" Visibility="Visible" Padding="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Width="140" Height="140" CornerRadius="8" Background="{StaticResource SpotifyLightGray}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock Text="&#xE8D6;" FontFamily="{StaticResource SymbolFont}" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource SpotifyGray}"/>
                        <Image x:Name="PlayerAlbumArt" Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock x:Name="TrackTitleText" Text="Track Title" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ArtistNameText" Text="Artist Name" FontSize="12" Foreground="{StaticResource SpotifyGray}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <Grid Grid.Row="2" Margin="0,0,0,10" MaxWidth="300" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressCurrentText" Text="0:00" Foreground="{StaticResource SpotifyGray}" FontSize="10" VerticalAlignment="Center"/>
                    <ProgressBar x:Name="ProgressBar" Grid.Column="1" Value="0" Maximum="100" Margin="8,0" Foreground="{StaticResource SpotifyGreen}" Background="#535353" Height="3"/>
                    <TextBlock x:Name="ProgressDurationText" Grid.Column="2" Text="0:00" Foreground="{StaticResource SpotifyGray}" FontSize="10" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="3" Margin="0,0,0,10" MaxWidth="300" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE994;" FontFamily="{StaticResource SymbolFont}" Foreground="{StaticResource SpotifyGray}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0" Maximum="1" StepFrequency="0.01" ValueChanged="VolumeSlider_ValueChanged"/>
                </Grid>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                    <Button x:Name="PrevButton" Click="PrevButton_Click" Background="Transparent" Foreground="White" Content="&#xE892;" FontFamily="{StaticResource SymbolFont}" FontSize="20" BorderThickness="0" VerticalAlignment="Center"/>
                    <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click" Background="White" Foreground="Black" Content="&#xE768;" FontFamily="{StaticResource SymbolFont}" FontSize="16" BorderThickness="0" CornerRadius="20" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button x:Name="NextButton" Click="NextButton_Click" Background="Transparent" Foreground="White" Content="&#xE893;" FontFamily="{StaticResource SymbolFont}" FontSize="20" BorderThickness="0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Search Layout -->
            <Grid x:Name="SearchPanel" Visibility="Collapsed" Padding="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="SearchBox" PlaceholderText="Search for songs or artists..." Background="#242424" Foreground="White" BorderThickness="0" Height="40" Margin="0,0,0,12" TextChanged="SearchBox_TextChanged"/>
                <ListView x:Name="SearchResultsList" Grid.Row="1" ItemTemplate="{StaticResource TrackItemTemplate}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="TrackItem_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Playlists Layout -->
            <Grid x:Name="PlaylistsPanel" Visibility="Collapsed" Padding="0,12,0,0">
                <ListView x:Name="PlaylistsList" ItemTemplate="{StaticResource PlaylistItemTemplate}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="PlaylistItem_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Queue Layout -->
            <Grid x:Name="QueuePanel" Visibility="Collapsed" Padding="0,12,0,0">
                <ListView x:Name="QueueList" ItemTemplate="{StaticResource TrackItemTemplate}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="TrackItem_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
